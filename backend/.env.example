# Port the API server listens on
PORT=4000

# Comma-separated list of origins allowed to call this API (your frontend URL(s))
CORS_ORIGIN=http://localhost:5173

# Path to the SQLite database file (created automatically on first run)
DB_PATH=./data/planner.db

# Secret used to sign login session tokens — set this to a long random
# string in any real deployment. Falls back to an insecure dev default
# locally so you don't have to generate one just to run `npm run dev`.
JWT_SECRET=

# Set to "production" when deployed. Enables secure, cross-site session
# cookies (needed when the frontend and API are on different domains) and
# a startup warning if JWT_SECRET is missing.
NODE_ENV=development
